# Server
PORT=3001
NODE_ENV=development

# Database PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/twitch_heroes

# Twitch
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret
TWITCH_EXTENSION_SECRET=your_extension_shared_secret_base64

# JWT
JWT_SECRET=your_jwt_secret_here

# Il tuo channel ID Twitch (broadcaster)
BROADCASTER_ID=your_broadcaster_id
